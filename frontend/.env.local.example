# URL base da API para build estático e runtime
# Em desenvolvimento local, aponta para o backend FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000

# Para deploy em produção (ex: Railway, Vercel), substitua pela URL real:
# NEXT_PUBLIC_API_URL=https://seu-backend.up.railway.app

# Nota: esta variável precisa ser NEXT_PUBLIC_ para estar disponível no browser.
# O build estático usa este valor para pré-renderizar páginas com dados da API.
# Se a API não responder durante o build, os dados fallback locais serão usados.
